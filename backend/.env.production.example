APP_NAME=OptiFlow API
APP_ENV=production
APP_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-frontend.example.com

DATABASE_URL=postgresql+psycopg://optiflow:replace-postgres-password@db:5432/optiflow
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

